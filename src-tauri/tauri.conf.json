{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BTC Lottery Pet",
  "version": "0.6.2",
  "identifier": "com.btc-lottery-pet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BTC Lottery Pet",
        "width": 360,
        "height": 260,
        "minWidth": 360,
        "minHeight": 260,
        "maxWidth": 360,
        "maxHeight": 260,
        "resizable": false,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost https://mempool.space https://blockstream.info https://blockchain.info; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
