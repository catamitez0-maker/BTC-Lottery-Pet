{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BTC Lottery Pet",
  "version": "0.2.0",
  "identifier": "com.btc-lottery-pet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BTC Lottery Pet",
        "width": 320,
        "height": 220,
        "minWidth": 320,
        "minHeight": 220,
        "maxWidth": 320,
        "maxHeight": 220,
        "resizable": false,
        "alwaysOnTop": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
